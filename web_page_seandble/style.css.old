h1 {
    text-align: center;
}

.center {
    text-align: center;
}

.header-row {
  display: grid;
  grid-template-columns: 1fr 120px;
}

.question {
  display: grid;
  grid-template-columns: 35px 1fr;
}

.summary-row {
  display: grid;
  grid-template-columns: 1fr 120px;
}
body {
    margin: 0;
    background: #cfcfcf;
    font-family: "Times New Roman", serif;
    color: #000;
  }

  .page {
    width: 900px;
    margin: 20px auto;
    padding: 20px;
    position: relative;
  }

  .top-line {
    border-top: 1px solid #333;
    padding-top: 8px;
  }

  .header-row {
    display: grid;
    grid-template-columns: 1fr 120px;
    gap: 20px;
    align-items: start;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 18px;
    font-weight: bold;
  }

  .score-title {
    text-align: center;
    font-weight: bold;
    font-size: 20px;
    margin-bottom: 2px;
  }

  .questions {
    display: grid;
    row-gap: 22px;
    font-size: 19px;
    line-height: 1.15;
  }

  .question {
    display: grid;
    grid-template-columns: 35px 1fr;
  }

  .score-boxes {
    border: 1px solid #333;
  }

  .score-cell {
    height: 49px;
    border-bottom: 1px solid #555;
  }

  .score-cell:last-child {
    border-bottom: none;
  }

  .summary {
    margin-top: 45px;
    margin-left: auto;
    width: 460px;
    font-size: 19px;
  }

  .summary-row {
    display: grid;
    grid-template-columns: 1fr 120px;
    align-items: center;
    margin-bottom: 18px;
  }

  .summary-text {
    text-align: right;
    padding-right: 10px;
  }

  .summary-text strong {
    font-weight: bold;
  }

  .note {
    display: block;
    font-style: italic;
    font-size: 17px;
    margin-top: 3px;
  }

  .small-box {
    height: 58px;
    border: 1px solid #333;
  }

  .thick-box {
    height: 76px;
    border: 4px solid #111;
  }

  .bottom-summary {
    margin-top: 48px;
  }

  